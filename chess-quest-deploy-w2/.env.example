# Copy this file to .env and fill in your Firebase values
# In Cloudflare Pages: Settings → Environment Variables → add each one

CHESS_QUEST_API_KEY=your_firebase_api_key
CHESS_QUEST_AUTH_DOMAIN=your_project.firebaseapp.com
CHESS_QUEST_PROJECT_ID=your_project_id
CHESS_QUEST_STORAGE_BUCKET=your_project.firebasestorage.app
CHESS_QUEST_SENDER_ID=your_sender_id
CHESS_QUEST_APP_ID=your_app_id
